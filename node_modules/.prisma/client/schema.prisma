// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String @id @default(uuid())
  telegramId String @unique
  firstName  String
  theme      String @default("dark")
  accent     String @default("pink")
  balance    Int    @default(0)

  coupleId String?
  couple   Couple? @relation(fields: [coupleId], references: [id])

  tasksCreated  Task[] @relation("TasksCreated")
  tasksAssigned Task[] @relation("TasksAssigned")
}

model Couple {
  id     String @id @default(uuid())
  code   String @unique // 6-char referral code
  users  User[]
  plans  Plan[]
  wishes Wish[]

  createdAt DateTime @default(now())
}

model Plan {
  id       String @id @default(uuid())
  coupleId String
  couple   Couple @relation(fields: [coupleId], references: [id])

  type   String // "day", "week", "month"
  text   String
  isDone Boolean @default(false)

  createdAt DateTime @default(now())
}

model Task {
  id     String @id @default(uuid())
  title  String
  points Int
  status String @default("active") // active, done

  creatorId String
  creator   User   @relation("TasksCreated", fields: [creatorId], references: [id])

  assigneeId String?
  assignee   User?   @relation("TasksAssigned", fields: [assigneeId], references: [id])

  createdAt DateTime @default(now())
}

model Wish {
  id       String @id @default(uuid())
  coupleId String
  couple   Couple @relation(fields: [coupleId], references: [id])

  title    String
  points   Int
  isBought Boolean @default(false)

  createdAt DateTime @default(now())
}
